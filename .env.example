# ── Database ──────────────────────────────────────────────────────────────────
# Postgres connection string. The docker-compose.yml default matches this value.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/social_media_agent

# ── Azure OpenAI ───────────────────────────────────────────────────────────────
# Required: your Azure OpenAI resource endpoint and deployment name.
AZURE_OPENAI_ENDPOINT=https://<your-resource>.openai.azure.com/
AZURE_OPENAI_DEPLOYMENT=gpt-4o

# API key for local development. In production, leave unset and use Managed Identity
# (App Service must have the "Cognitive Services OpenAI User" RBAC role).
AZURE_OPENAI_API_KEY=

# Optional: API version for Azure OpenAI SDK. Defaults to 2024-10-21 (GA stable).
AZURE_OPENAI_API_VERSION=2024-10-21

# ── LinkedIn OAuth ─────────────────────────────────────────────────────────────
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
# Must match the redirect URI registered in your LinkedIn app settings.
LINKEDIN_REDIRECT_URI=http://localhost:3000/api/auth/linkedin/callback

# 32-byte base64 key for AES-256-GCM token encryption.
# Generate with: openssl rand -base64 32
LINKEDIN_TOKEN_ENCRYPTION_KEY=

# ── Dashboard ──────────────────────────────────────────────────────────────────
# Single-user password gate (WI-13). Choose something strong (≥8 chars).
DASHBOARD_PASSWORD=

# Optional: separate HMAC-SHA256 signing secret for session cookies.
# If unset, DASHBOARD_PASSWORD is used as the signing key (fine for solo use).
# Recommended: generate with: openssl rand -base64 32
SESSION_SECRET=

# ── App ────────────────────────────────────────────────────────────────────────
NODE_ENV=development
APP_BASE_URL=http://localhost:3000
